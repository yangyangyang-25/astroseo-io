---
import { siteConfig } from "../config/site";
---

<header class="shell" style="padding: 22px 20px 12px;">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;">
    <a href={import.meta.env.BASE_URL} style="font-size:1.2rem;font-weight:700;">
      {siteConfig.title}
    </a>
    <nav style="display:flex;gap:16px;flex-wrap:wrap;">
      {siteConfig.nav.map((item) => (
        <a href={item.href === "/" ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}${item.href.slice(1)}`}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
